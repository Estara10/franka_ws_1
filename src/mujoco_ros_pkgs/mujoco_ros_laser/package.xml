<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>mujoco_ros_laser</name>
  <version>0.9.0</version>
  <description>MuJoCo ROS Laser Plugin</description>


  <maintainer email="dleins@techfak.uni-bielefeld.de">David Leins</maintainer>
  <author>David P. Leins</author>

  <license>BSD</license>

  <buildtool_depend condition="$ROS_VERSION == 1">catkin</buildtool_depend>
  <buildtool_depend condition="$ROS_VERSION == 2">ament_cmake</buildtool_depend>
  <depend condition="$ROS_VERSION == 1">roscpp</depend>
  <depend condition="$ROS_VERSION == 1">pluginlib</depend>
  <depend condition="$ROS_VERSION == 1">mujoco_ros</depend>
  <depend condition="$ROS_VERSION == 1">mujoco_ros_sensors</depend>
  <depend condition="$ROS_VERSION == 1">sensor_msgs</depend>

  <test_depend condition="$ROS_VERSION == 1">rostest</test_depend>

  <export>
    <mujoco_ros plugin="${prefix}/mujoco_laser_plugin.xml" />
    <build_type condition="$ROS_VERSION == 1">catkin</build_type>
    <build_type condition="$ROS_VERSION == 2">ament_cmake</build_type>
  </export>
</package>
