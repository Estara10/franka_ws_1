<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>mujoco_ros_mocap</name>
  <version>0.9.0</version>
  <description>The mujoco_ros_mocap plugin package</description>

  <url type="repository">https://github.com/ubi-agni/mujoco_ros_pkgs</url>
  <url type="bugtracker">https://github.com/ubi-agni/mujoco_ros_pkgs/issues</url>

  <maintainer email="dleins@techfak.de">David Leins</maintainer>
  <author>David Leins</author>

  <license>BSD</license>

  <buildtool_depend condition="$ROS_VERSION == 1">catkin</buildtool_depend>
  <buildtool_depend condition="$ROS_VERSION == 2">ament_cmake</buildtool_depend>
  <depend condition="$ROS_VERSION == 1">mujoco_ros</depend>
  <depend condition="$ROS_VERSION == 1">mujoco_ros_msgs</depend>

  <test_depend condition="$ROS_VERSION == 1">rostest</test_depend>

  <export>
    <mujoco_ros plugin="${prefix}/mocap_plugin.xml" />
    <build_type condition="$ROS_VERSION == 1">catkin</build_type>
    <build_type condition="$ROS_VERSION == 2">ament_cmake</build_type>
  </export>
</package>
