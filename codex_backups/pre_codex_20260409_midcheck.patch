+        p.descend_waypoint_scale = 1.35;
+
+        p.place_vel_scale = 0.76;
+        p.place_acc_scale = 0.62;
+        p.place_waypoint_scale = 1.35;
+        return p;
+    }
+
+    // rigid 或未知模式均回退到基线剖面。
+    return p;
